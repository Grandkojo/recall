# Recall frontend environment.
# Copy to `.env.local` and fill in. All vars must be prefixed with VITE_ to reach the client.

# Base URL of the FastAPI backend.
# The backend README maps the API to port 8001 via docker-compose.
VITE_API_URL=http://localhost:8001

# Firebase Web App config (Project settings -> General -> Your apps -> Web app).
# Enable Email/Password in Firebase Auth -> Sign-in method. The same Firebase
# project's service-account JSON must be set as FIREBASE_SERVICE_ACCOUNT_JSON
# on the backend so it can verify the ID tokens this app sends.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=